.DS_Store

# Local env files (keep secrets out of git)
.env

# Laravel app
src/vendor/
src/node_modules/
src/.env
src/.phpunit.result.cache
src/storage/*.key
src/storage/logs/
src/storage/app/ml/

# Supabase connector env (contains secrets)
src/database/storage.env

# IDE
# .vscode/ - Commented out to include workspace configuration for GitHub Copilot
# For comprehensive Copilot workspace solution, we include:
# - settings.json (workspace settings)
# - extensions.json (recommended extensions)
# - launch.json (debug configurations)
# Uncomment if you prefer to keep personal IDE settings private

# Misc
.env.local

# CXFlow runtime data (memory, audit logs, etc.)
.cxflow/memory/
.cxflow/audit/
.cxflow/metadata/

# Local credentials (NEVER commit)
creds/
creds/**/*.pem
creds/**/*.key

# Python cache
__pycache__/
*.pyc
*.pyo
workflows/__pycache__/
