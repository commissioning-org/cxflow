# Docker Compose environment (copy to .env)
# cp .env.example .env

APP_PORT=8080
PHPMYADMIN_PORT=8081
MYSQL_PORT=3306

MYSQL_DATABASE=laravel
MYSQL_USER=laravel
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

# Optional: SQL Server
MSSQL_PORT=1433
MSSQL_PID=Developer
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# Redis
REDIS_PORT=6379

# Mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Vite
VITE_PORT=5173

# AutoML service
ML_PORT=8090
AUTOML_BASE_URL=http://ml:8000

# AutoML webhook (optional)
# Put your Power Automate URL here (do not commit real secrets)
AUTOML_WEBHOOK_ENABLED=false
AUTOML_WEBHOOK_URL=
AUTOML_WEBHOOK_TIMEOUT_SECONDS=15
AUTOML_WEBHOOK_INCLUDE_ROWS=false

# Assistant token (DO NOT commit real tokens)
ASSISTANT_API_KEY=
ASSISTANT_MODEL=grok-3
ASSISTANT_BASE_URL=https://models.inference.ai.azure.com
ASSISTANT_ALLOW_OTHER_MODELS=false
ASSISTANT_TIMEOUT_SECONDS=60

# Legacy compatibility (optional)
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=grok-3
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com
