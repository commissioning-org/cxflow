# Docker Compose environment (copy to .env)
# cp .env.example .env

APP_PORT=8080
PHPMYADMIN_PORT=8081
MYSQL_PORT=3306

MYSQL_DATABASE=laravel
MYSQL_USER=laravel
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

# Optional: SQL Server
MSSQL_PORT=1433
MSSQL_PID=Developer
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# Redis
REDIS_PORT=6379

# Mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Vite
VITE_PORT=5173

# AutoML service
ML_PORT=8090
AUTOML_BASE_URL=http://ml:8000

# AutoML webhook (optional)
# Put your Power Automate URL here (do not commit real secrets)
AUTOML_WEBHOOK_ENABLED=false
AUTOML_WEBHOOK_URL=
AUTOML_WEBHOOK_TIMEOUT_SECONDS=15
AUTOML_WEBHOOK_INCLUDE_ROWS=false
AUTOML_WEBHOOK_SAMPLE_ROWS=50
AUTOML_WEBHOOK_SAMPLE_PREDICTIONS=200
AUTOML_WEBHOOK_MODE=both
AUTOML_WEBHOOK_SINGLE_EVENT=ml.data
AUTOML_WEBHOOK_FULL_PAYLOAD=false

# ML automation (internal)
ML_AUTOMATION_ENABLED=false
ML_AUTOMATION_SOURCE=
ML_AUTOMATION_FORMAT=auto
ML_AUTOMATION_TARGET=
ML_AUTOMATION_PROBLEM=
ML_AUTOMATION_METRIC=
ML_AUTOMATION_MAX_ROWS=5000
ML_AUTOMATION_INCLUDE_ROWS=false

# ML automation webhook (optional)
ML_AUTOMATION_WEBHOOK_ENABLED=false
ML_AUTOMATION_WEBHOOK_URL=
ML_AUTOMATION_WEBHOOK_TIMEOUT_SECONDS=15
ML_AUTOMATION_WEBHOOK_INCLUDE_ROWS=false
ML_AUTOMATION_WEBHOOK_SAMPLE_ROWS=50
ML_AUTOMATION_WEBHOOK_MODE=both
ML_AUTOMATION_WEBHOOK_SINGLE_EVENT=ml.data
ML_AUTOMATION_WEBHOOK_SINGLE_SUMMARY=true
ML_AUTOMATION_WEBHOOK_FULL_PAYLOAD=false

# Optional internal analysis helpers
ML_AUTOMATION_ASSISTANT_ENABLED=true
ML_AUTOMATION_MODEL_CARD_ENABLED=true

# Assistant token (DO NOT commit real tokens)
ASSISTANT_API_KEY=
ASSISTANT_MODEL=grok-3
ASSISTANT_BASE_URL=https://models.inference.ai.azure.com
ASSISTANT_ALLOW_OTHER_MODELS=false
ASSISTANT_TIMEOUT_SECONDS=60

# Legacy compatibility (optional)
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=grok-3
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com
