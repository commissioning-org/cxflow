# Example environment values for the Supabase File API connector.
# Copy to storage.env and fill in real values in your secure environment.
# DO NOT COMMIT real secrets.

SUPABASE_DATABASE_PASSWORD=
SUPABASE_ACCESS_KEY=
SUPABASE_S3_ENDPOINT=https://<your-project>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ENPOINT=https://<your-project>.storage.supabase.co/storage/v1/s3
SUPABASE_API_SECRET_KEY=sb_secret_<redacted>
SUPABASE_API_SERVICE_ROLE=<base64-or-jwt-like-service-role-key>
SUPABASE_PROJECT_URL=https://<your-project>.supabase.co
