# Superset Environment Variables
# Copy this file to .env and configure for your environment

# =============================================================================
# SECURITY
# =============================================================================

# Secret key for session signing and encryption
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=changethissecretkey

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL password for Superset metadata database
POSTGRES_PASSWORD=superset

# =============================================================================
# ADMIN USER
# =============================================================================

# Initial admin user credentials
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_EMAIL=admin@superset.local
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_FIRST_NAME=Admin
SUPERSET_ADMIN_LAST_NAME=User

# =============================================================================
# SUPERSET CONFIGURATION
# =============================================================================

# Port to expose Superset on host
SUPERSET_PORT=8088

# Load example data (set to 'yes' for first-time demo)
SUPERSET_LOAD_EXAMPLES=no

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Mapbox API key for map visualizations (optional)
MAPBOX_API_KEY=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable embedding (set in superset_config.py)
# ENABLE_TEMPLATE_PROCESSING=True
# ENABLE_TEMPLATE_REMOVE_FILTERS=True
