#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")/.."

if [ ! -f "src/artisan" ]; then
  echo "No Laravel app detected at ./src (missing src/artisan)."
  echo "Run: bin/init"
  exit 1
fi

stub_root=".stubs/mlops"

copy_stub() {
  local rel="$1"
  local src_file="$stub_root/$rel"
  local dest_file="src/$rel"

  mkdir -p "$(dirname "$dest_file")"
  cp "$src_file" "$dest_file"
}

echo "Installing internal ML automation scaffolding into ./src ..."

# Config + services
copy_stub "config/ml_automation.php"
copy_stub "app/Services/MlAutomation/MlWebhookNotifier.php"
copy_stub "app/Services/MlAutomation/DatasetLoader.php"
copy_stub "app/Services/MlAutomation/MlAutomationPipeline.php"

# Jobs + commands
copy_stub "app/Jobs/RunMlAutomation.php"
copy_stub "app/Console/Commands/MlAutomate.php"
copy_stub "app/Console/Commands/MlMonitor.php"

# Schemas (for Power Automate / external validation)
copy_stub "resources/schemas/ml_ingestion_event.schema.json"
copy_stub "resources/schemas/ml_ingestion_source.schema.json"

# Optional DB persistence (migrations + models)
copy_stub "app/Models/MlDataset.php"
copy_stub "app/Models/MlModel.php"
copy_stub "app/Models/MlRun.php"
copy_stub "database/migrations/2025_01_01_000001_create_ml_datasets_table.php"
copy_stub "database/migrations/2025_01_01_000002_create_ml_models_table.php"
copy_stub "database/migrations/2025_01_01_000003_create_ml_runs_table.php"

# Add env hints (idempotent)
laravel_env_example="src/.env.example"
if [ -f "$laravel_env_example" ] && ! grep -q "ML_AUTOMATION_ENABLED" "$laravel_env_example"; then
  cat >> "$laravel_env_example" <<'ENV'

# ML automation (internal)
ML_AUTOMATION_ENABLED=false
ML_AUTOMATION_SOURCE=
ML_AUTOMATION_FORMAT=auto
ML_AUTOMATION_TARGET=
ML_AUTOMATION_PROBLEM=
ML_AUTOMATION_METRIC=
ML_AUTOMATION_MAX_ROWS=5000
ML_AUTOMATION_INCLUDE_ROWS=false

# ML automation webhook (optional)
ML_AUTOMATION_WEBHOOK_ENABLED=false
ML_AUTOMATION_WEBHOOK_URL=
ML_AUTOMATION_WEBHOOK_TIMEOUT_SECONDS=15
ML_AUTOMATION_WEBHOOK_INCLUDE_ROWS=false
ML_AUTOMATION_WEBHOOK_SAMPLE_ROWS=50

# Webhook payload modes
# - multiple: stage-by-stage events (ml.ingest.completed, ml.train.completed, ...)
# - single: send a single normalized event name with the original event nested
# - both: send both styles
ML_AUTOMATION_WEBHOOK_MODE=both
ML_AUTOMATION_WEBHOOK_SINGLE_EVENT=ml.data
ML_AUTOMATION_WEBHOOK_SINGLE_SUMMARY=true
ML_AUTOMATION_WEBHOOK_FULL_PAYLOAD=true

# Optional internal analysis helpers
ML_AUTOMATION_ASSISTANT_ENABLED=true
ML_AUTOMATION_MODEL_CARD_ENABLED=true
ENV
fi

laravel_env="src/.env"
if [ -f "$laravel_env" ] && ! grep -q "ML_AUTOMATION_ENABLED" "$laravel_env"; then
  cat >> "$laravel_env" <<'ENV'

# ML automation (internal)
ML_AUTOMATION_ENABLED=false
ML_AUTOMATION_SOURCE=
ML_AUTOMATION_FORMAT=auto
ML_AUTOMATION_TARGET=
ML_AUTOMATION_PROBLEM=
ML_AUTOMATION_METRIC=
ML_AUTOMATION_MAX_ROWS=5000
ML_AUTOMATION_INCLUDE_ROWS=false

# ML automation webhook (optional)
ML_AUTOMATION_WEBHOOK_ENABLED=false
ML_AUTOMATION_WEBHOOK_URL=
ML_AUTOMATION_WEBHOOK_TIMEOUT_SECONDS=15
ML_AUTOMATION_WEBHOOK_INCLUDE_ROWS=false
ML_AUTOMATION_WEBHOOK_SAMPLE_ROWS=50

# Webhook payload modes
ML_AUTOMATION_WEBHOOK_MODE=both
ML_AUTOMATION_WEBHOOK_SINGLE_EVENT=ml.data
ML_AUTOMATION_WEBHOOK_SINGLE_SUMMARY=true
ML_AUTOMATION_WEBHOOK_FULL_PAYLOAD=true

# Optional internal analysis helpers
ML_AUTOMATION_ASSISTANT_ENABLED=true
ML_AUTOMATION_MODEL_CARD_ENABLED=true
ENV
fi

# Add schedule hooks (idempotent). Prefer routes/console.php (Laravel 10/11).
console_routes="src/routes/console.php"
if [ -f "$console_routes" ] && ! grep -q "ML_AUTOMATION_SCHEDULE" "$console_routes"; then
  cat >> "$console_routes" <<'PHP'

// ML_AUTOMATION_SCHEDULE (internal)
// Runs the end-to-end automation pipeline periodically.
// You can tune cadence or disable via ML_AUTOMATION_ENABLED.
\Illuminate\Support\Facades\Schedule::command('ml:automate')
    ->everyThirtyMinutes()
    ->withoutOverlapping();

\Illuminate\Support\Facades\Schedule::command('ml:monitor')
    ->hourly()
    ->withoutOverlapping();
PHP
fi

echo "Done."
echo "Try: php artisan ml:automate --sync"
